model:
  default: "anthropic/claude-opus-4.6"
  provider: "auto"

terminal:
  backend: "local"
  cwd: "."
  timeout: 180
  lifetime_seconds: 300

memory:
  memory_enabled: true
  user_profile_enabled: true

delegation:
  max_iterations: 40
  default_toolsets: ["file", "web"]

timezone: "Asia/Shanghai"
